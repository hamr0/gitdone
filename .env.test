# Test Environment Configuration
# This file is used during Playwright E2E tests

# MailHog SMTP Configuration (for automated email testing)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test
SMTP_PASS=test

# MailHog doesn't require real authentication, but we need non-empty values
# to pass the SMTP configuration check in emailService.js
# Emails are captured locally and accessible via http://localhost:8025

# MailHog Web UI: http://localhost:8025
# MailHog API: http://localhost:8025/api/v2/messages

# Frontend URL (for magic links in emails)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=test
